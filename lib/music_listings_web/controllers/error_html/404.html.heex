<html lang="en" class="h-full bg-ink antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 - Page Not Found</title>
    <link phx-track-static rel="stylesheet" href={~p"/fonts/after-dark.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
  </head>
  <body class="min-h-full bg-ink text-paper font-sans">
    <main class="grid min-h-full place-items-center px-5 sm:px-8">
      <div class="text-center">
        <p class="kicker flex items-center justify-center gap-2">
          <span class="inline-block h-2 w-8 bg-spotlight"></span> Lost in the dark
        </p>
        <p class="headline mt-4 text-7xl text-spotlight glow sm:text-8xl">
          404
        </p>
        <h1 class="headline mt-4 text-3xl text-paper sm:text-4xl">
          Page not found
        </h1>
        <p class="mt-4 text-pretty text-base text-paper-dim">
          Sorry, we couldn't find the page you're looking for.
        </p>
        <div class="mt-8">
          <a
            href="/"
            class="inline-flex items-center justify-center gap-1 rounded-full bg-spotlight/10 px-4 py-1.5 text-sm font-medium text-spotlight ring-1 ring-inset ring-spotlight/30 transition-colors hover:text-ink hover:bg-spotlight hover:ring-spotlight"
          >
            Back to homepage
          </a>
        </div>
      </div>
    </main>
  </body>
</html>
