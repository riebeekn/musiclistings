# This is a template file containing the environment settings
# required to run the application.  Copy this file to .envrc
# and update the setting values if desired

# You will need to run source .envrc from your terminal prior to starting
# the application.  Or install https://direnv.net/docs/installation.html
export ADMIN_EMAIL="admin@example.com"

# Render's EXTERNAL postgres connection string. Used by bin/pull-prod-db.sh (to pull
# prod data down locally) and bin/crawl-venue.sh (to crawl a venue from this machine
# and write the results to prod). Requires your IP to be on the Render database's
# inbound allowlist.
export PROD_DB_URL="postgresql://user:password@host.render.com/database"
